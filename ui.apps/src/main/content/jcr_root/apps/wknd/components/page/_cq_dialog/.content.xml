<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured">
    <content jcr:primaryType="nt:unstructured">
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured">
                <items jcr:primaryType="nt:unstructured">
                    <wknd
                        jcr:primaryType="nt:unstructured"
                        jcr:title="WKND"
                        sling:orderBefore="basic"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured">
                                <items jcr:primaryType="nt:unstructured">
                                    <wkndId
                                        cq:showOnCreate="{Boolean}true"
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        emptyText="WKND-####"
                                        fieldDescription="Enter the WKND ID code in the format WKND-####"
                                        fieldLabel="WKND ID"
                                        name="./wkndId"/>
                                </items>
                            </column>
                        </items>
                    </wknd>
                    <basic
                        jcr:primaryType="nt:unstructured"
                        sling:orderBefore="advanced">
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured">
                                <items jcr:primaryType="nt:unstructured">
                                    <tagLine
                                        jcr:primaryType="nt:unstructured"
                                        sling:orderBefore="htmlid"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        emptyText="Enter a short, but sweet, tag line for this page"
                                        fieldLabel="Tag line"
                                        name="./tagLine"/>
                                </items>
                            </column>
                        </items>
                    </basic>
                    <socialmedia
                        jcr:primaryType="nt:unstructured"
                        sling:orderBefore="cloudservices">
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured">
                                <items jcr:primaryType="nt:unstructured">
                                    <section jcr:primaryType="nt:unstructured">
                                        <items jcr:primaryType="nt:unstructured">
                                            <facebookAppId
                                                jcr:primaryType="nt:unstructured"
                                                sling:hideResource="{Boolean}true"/>
                                        </items>
                                    </section>
                                </items>
                            </column>
                        </items>
                    </socialmedia>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
